*.FCStd.bak
*.asd
*.log
# FreeCAD lock files
*.lock

# ==========================================
# Python Environment (Backend & Scripts)
# ==========================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/
.env
.venv
pip-log.txt
pip-delete-this-directory.txt

# ==========================================
# Node / Frontend (If using JS/TS frameworks)
# ==========================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.eslintcache

# ==========================================
# Mobile Apps (Flutter / React Native)
# ==========================================
.generated/
.dart_tool/
.packages
.pub-cache/
.pub/
/build/
# Mobile signing keys and platform-specific builds
.android/
.ios/
*.keystore
*.jks

# ==========================================
# Security, Local Configurations & DBs
# ==========================================
.env.local
.env.*.local
.env.development.local
.env.test.local
.env.production.local
*.db
*.sqlite3

# ==========================================
# Operating System (OS) Specific Files
# ==========================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# NiceGUI runtime storage
.nicegui/

# Certificats TLS locaux (clés privées, ne jamais committer)
*.pem
*.key
